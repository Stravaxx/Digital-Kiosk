{
  "instanceId": "kiosk-agent-default",
  "apiBaseUrl": "http://127.0.0.1:4173",
  "renderer": {
    "linux": {
      "command": "/usr/bin/chromium-browser",
      "args": [
        "--kiosk",
        "--start-fullscreen",
        "http://127.0.0.1:4173/player"
      ]
    },
    "windows": {
      "command": "msedge.exe",
      "args": [
        "--kiosk",
        "http://192.168.1.87:4173/player",
        "--edge-kiosk-type=fullscreen",
        "--no-first-run",
        "--disable-features=Translate,TranslateUI,msEdgeTranslate"
      ]
    }
  },
  "heartbeat": {
    "intervalSeconds": 10,
    "staleAfterSeconds": 90,
    "offlineAfterSeconds": 180
  },
  "storage": {
    "snapshotPath": "./data/last-known-good.json",
    "cachePath": "./data/cache",
    "maxBytes": 2147483648
  },
  "watchdog": {
    "enabled": true,
    "rendererCheckSeconds": 5,
    "rendererRestartBackoffSeconds": 2
  }
}
