[Unit]
Description=Digital Signage Kiosk Agent (C++)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/digital-signage/kiosk-agent-cpp
ExecStart=/opt/digital-signage/kiosk-agent-cpp/build/kiosk-agent /opt/digital-signage/kiosk-agent-cpp/config/agent-config.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
