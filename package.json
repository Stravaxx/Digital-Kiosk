{
  "name": "digital-signage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run docs:build",
    "predev:ip": "npm run docs:build",
    "preprod": "npm run docs:build",
    "api": "cross-env API_ONLY=true PORT=8787 node server.cjs",
    "api:prod": "node server.cjs",
    "prod": "vite build && node server.cjs",
    "prod:all": "npm run prod",
    "build": "vite build",
    "serve:dist": "node scripts/serve-dist.cjs",
    "dev": "concurrently \"npm run api\" \"vite --port 4173 --strictPort\"",
    "dev:all": "npm run dev",
    "dev:ip": "concurrently \"npm run api\" \"vite --host 0.0.0.0 --port 4173 --strictPort\"",
    "preview": "vite preview",
    "preview:ip": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "panel:prod": "cross-env PORT=8080 node server.cjs",
    "player:prod": "cross-env API_ONLY=true PORT=80 node server.cjs",
    "auth:reset": "node scripts/reset-admin-password.cjs",
    "docs:api": "typedoc --options typedoc.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "node scripts/build-docs.cjs",
    "docs:preview": "vitepress preview docs",
    "agent:cpp:configure": "cmake -S kiosk-agent-cpp -B kiosk-agent-cpp/build",
    "agent:cpp:build": "cmake --build kiosk-agent-cpp/build --config Release",
    "agent:cpp:run": "kiosk-agent-cpp/build/kiosk-agent kiosk-agent-cpp/config/agent-config.example.json",
    "changelog:generate": "node scripts/generate-changelog.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
