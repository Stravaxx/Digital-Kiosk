{
  "name": "digital-signage",
  "private": true,
  "version": "1.2.0",
  "description": "Digital Kiosk signage platform with web admin, Electron desktop shells, player runtime, local Node API and Flutter manager.",
  "author": "Stravaxx",
  "license": "UNLICENSED",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"vite --config src-vite/vite.config.ts\"",
    "dev:ip": "concurrently \"npm run api\" \"vite --config src-vite/vite.config.ts --host 0.0.0.0\"",
    "build": "vite build --config src-vite/vite.config.ts",
    "start": "concurrently \"npm run api\" \"vite preview --config src-vite/vite.config.ts --host 0.0.0.0 --port 4173\"",
    "desktop": "electron electron/main.cjs",
    "desktop:player": "electron electron/player-main.cjs",
    "desktop:win": "npm run build && npm --prefix electron run build && electron electron/main.cjs",
    "electron:renderer:build": "npm --prefix electron run build",
    "electron:bundle": "node scripts/prepare-electron-bundle.cjs",
    "package:admin:win": "npm run build && npm run electron:renderer:build && npm run electron:bundle && electron-builder --config electron-builder.admin.json --win nsis portable --publish never",
    "package:player:win": "npm run build && electron-builder --config electron-builder.player.json --win nsis portable --publish never",
    "api": "cross-env API_ONLY=true PORT=8787 node server.cjs",
    "api:prod": "node server.cjs",
    "prod": "npm run build && npm run start",
    "serve:dist": "node scripts/serve-dist.cjs",
    "update:monitor": "node scripts/run-update-monitor.cjs",
    "update:monitor:win": "powershell -ExecutionPolicy Bypass -File scripts/run-update-monitor.ps1",
    "update:monitor:linux": "bash scripts/run-update-monitor.sh",
    "flutter:devices": "node scripts/flutter-manager.cjs devices",
    "flutter:run:android": "node scripts/flutter-manager.cjs run -d android",
    "flutter:run:ios": "node scripts/flutter-manager.cjs run -d ios",
    "flutter:run:linux": "node scripts/flutter-manager.cjs run -d linux",
    "flutter:run:macos": "node scripts/flutter-manager.cjs run -d macos",
    "flutter:run:windows:workaround": "powershell -ExecutionPolicy Bypass -File scripts/flutter-windows-workaround.ps1 -Mode run",
    "flutter:build:linux": "node scripts/flutter-manager.cjs build linux --release",
    "flutter:build:macos": "node scripts/flutter-manager.cjs build macos --release",
    "flutter:build:windows:workaround": "powershell -ExecutionPolicy Bypass -File scripts/flutter-windows-workaround.ps1 -Mode build-windows",
    "flutter:build:apk:workaround": "powershell -ExecutionPolicy Bypass -File scripts/flutter-windows-workaround.ps1 -Mode build-apk",
    "flutter:build:appbundle:workaround": "powershell -ExecutionPolicy Bypass -File scripts/flutter-windows-workaround.ps1 -Mode build-appbundle",
    "api:verify": "node scripts/security/verify-api.cjs",
    "auth:reset": "node scripts/reset-admin-password.cjs",
    "docs:api": "typedoc --options typedoc.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "node scripts/build-docs.cjs",
    "docs:preview": "vitepress preview docs",
    "changelog:generate": "node scripts/generate-changelog.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:init": "prisma migrate dev --name init",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate:from-json": "node scripts/migrate-to-prisma.cjs",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.0",
    "@prisma/client": "^5.8.0",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "date-fns": "3.6.0",
    "express": "^5.2.1",
    "ical": "^0.8.0",
    "lucide-react": "0.487.0",
    "luxon": "^3.7.2",
    "motion": "12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.9.3",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "systeminformation": "^5.31.5",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/vite": "^4.1.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ical": "^0.8.3",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^37.10.3",
    "prisma": "^5.8.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.12",
    "typedoc": "^0.28.13",
    "typescript": "^5",
    "electron-builder": "^26.0.12",
    "vite": "^7.1.7",
    "vitepress": "^2.0.0-alpha.12",
    "vitest": "^4.1.0"
  }
}
