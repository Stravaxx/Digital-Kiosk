    "@types/ical": "^0.8.3",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.3",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "4.7.0",
    "supertest": "^7.1.4",
    "tailwindcss": "4.1.12",
    "typedoc": "^0.28.13",
    "vite": "6.3.5",
    "vitepress": "^2.0.0-alpha.12",
