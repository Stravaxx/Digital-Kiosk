{
  "entryPoints": [
    "src-vite/services/**/*.ts",
    "src-vite/shared/**/*.ts",
    "src-vite/api/**/*.ts",
    "src-vite/player/**/*.ts",
    "src-vite/app/**/*.ts",
    "src-vite/app/**/*.tsx"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.d.ts"
  ],
  "out": "docs-api",
  "tsconfig": "tsconfig.json",
  "name": "Digital Signage API",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "sort": ["source-order"],
  "skipErrorChecking": true
}
